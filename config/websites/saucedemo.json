{
  "website_name": "SauceDemo",
  "base_url": "https://www.saucedemo.com",
  "credentials": {
    "username": "standard_user",
    "password": "secret_sauce"
  },
  "locators": {
    "login": {
      "username_field": ["id", "user-name"],
      "password_field": ["id", "password"],
      "login_button": ["id", "login-button"]
    },
    "inventory": {
      "inventory_container": ["id", "inventory_container"],
      "first_add_to_cart": ["xpath", "(//button[text()='Add to cart'])[1]"],
      "cart_badge": ["class name", "shopping_cart_badge"],
      "cart_icon": ["class name", "shopping_cart_link"],
      "menu_btn": ["id", "react-burger-menu-btn"],
      "logout_link": ["id", "logout_sidebar_link"]
    },
    "cart": {
      "cart_list": ["class name", "cart_list"],
      "checkout_button": ["id", "checkout"],
      "remove_button": ["xpath", "(//button[text()='Remove'])[1]"]
    }
  },
  "settings": {
    "max_retries": 3,
    "timeout": 15
  }
}

  },
  "locators": {
    "login": {
      "username_field": ["css selector", "[data-qa='login-email']"],
      "password_field": ["css selector", "[data-qa='login-password']"],
      "login_button": ["css selector", "[data-qa='login-button']"]
    },
    "inventory": {
      "inventory_container": ["class name", "features_items"],
      "first_add_to_cart": ["xpath", "(//a[contains(text(), 'Add to cart')])[1]"],
      "cart_badge": ["xpath", "//a[@href='/view_cart']//b"],
      "cart_icon": ["xpath", "//a[@href='/view_cart']"],
      "menu_btn": ["xpath", "//a[@href='/logout']"],
      "logout_link": ["xpath", "//a[@href='/logout']"]
    },
    "cart": {
      "cart_list": ["id", "cart_info_table"],
      "checkout_button": ["class name", "check_out"],
      "remove_button": ["class name", "cart_quantity_delete"]
    }
  },
  "settings": {
    "max_retries": 2,
    "timeout": 25
  }
}
